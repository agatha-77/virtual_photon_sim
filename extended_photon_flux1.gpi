
set palette cubehelix
set logscale zcb
unset key
#set pm3d
set hidden3d

set format cb "10^{%L}"

set decimalsign ","

set xlabel font ",14"
set ylabel font ",14"
set xtics font ",12"
set ytics font ",12"
set cbtics font ",10"
set title font ",14"

set cblabel offset 2
set cbtics rotate by 45 left

set xlabel "b [fm]"
set ylabel "{/Symbol w} (MeV)"
set title "N({/Symbol w},b) - Wood Saxon"

splot 'data/photon_flux1.dat' u 1:2:3 w l


pause -1
